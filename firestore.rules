rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // 1. GLOBAL SAFETY NET
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // 2. GLOBAL HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'kennymeico@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // -------------------------------------------------------------------------
    // 3. ENTITY VALIDATORS
    // -------------------------------------------------------------------------
    
    function isValidTestimony(data) {
      return data.keys().hasAll(['author', 'content', 'contact', 'status', 'id', 'image', 'date'])
        && data.keys().size() == 7
        && data.author is string && data.author.size() >= 2 && data.author.size() <= 100
        && data.content is string && data.content.size() >= 10 && data.content.size() <= 2000
        && data.contact is string && data.contact.size() <= 100
        && data.status in ['PENDING', 'APPROVED', 'REJECTED']
        && data.id is string
        && data.image is string
        && data.date is string;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['testimonyId', 'author', 'content', 'createdAt'])
        && data.keys().size() == 4
        && data.testimonyId is string
        && data.author is string && data.author.size() >= 2 && data.author.size() <= 100
        && data.content is string && data.content.size() >= 1 && data.content.size() <= 500
        && data.createdAt == request.time;
    }

    // -------------------------------------------------------------------------
    // 4. COLLECTION MATCHES
    // -------------------------------------------------------------------------

    match /testimonies/{testimonyDocId} {
      // Public can read approved testimonies
      allow list: if existing().status == 'APPROVED';
      // Admins can read everything
      allow get: if existing().status == 'APPROVED' || isAdmin();
      allow list: if isAdmin() && incoming() == null; // Multi-list for admin

      // Public can submit pending testimonies
      allow create: if isValidTestimony(incoming()) && incoming().status == 'PENDING';

      // Admin can update status
      allow update: if isAdmin() && isValidTestimony(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status'])
      );

      allow delete: if isAdmin();
    }

    match /comments/{commentId} {
      // Public can read comments for a testimony
      allow list: if resource.data.testimonyId != null; 
      
      // Public can create comments
      allow create: if isValidComment(incoming());
      
      allow update, delete: if isAdmin();
    }

    match /devotions/{devotionId} {
      allow read: if true;
      allow update: if 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']))
        || isAdmin();
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
    }
  }
}
